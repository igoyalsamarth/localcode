# Copy to .env and fill in values. Do not commit .env.
# Use KEY=value (export prefix is optional with python-dotenv).

# -----------------------------------------------------------------------------
# Database (required) — any PostgreSQL you run (local Docker, RDS, managed host, etc.)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# -----------------------------------------------------------------------------
# RabbitMQ (required for event publisher and workers)
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# -----------------------------------------------------------------------------
# GitHub OAuth — user login only (profile + email; see api/auth.py).
# Repo/org access: configure the GitHub App and installation flow, not these scopes.
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# -----------------------------------------------------------------------------
# GitHub App — bot identity, installation tokens, webhooks
# -----------------------------------------------------------------------------
# Client ID from the app settings page (recommended JWT iss claim).
GITHUB_APP_CLIENT_ID=
# App-level OAuth secret (if you use OAuth flows for the app; often unused for server JWT).
GITHUB_APP_CLIENT_SECRET=
# Numeric App ID from app settings.
GITHUB_APP_ID=
# URL slug: https://github.com/apps/<GITHUB_APP_SLUG> (optional; avoids one GET /app when resolving bot git identity)
GITHUB_APP_SLUG=

# PEM private key (generate in GitHub App settings). For a single-line .env, escape newlines as \n:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# Webhook signing secret — must match GitHub App → Webhooks → Secret.
GITHUB_WEBHOOK_SECRET=

# REST API calendar version (X-GitHub-Api-Version). Default in code: 2026-03-21.
# GITHUB_REST_API_VERSION=2026-03-21

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Frontend origin (OAuth redirect, Dodo checkout return_url / cancel_url). Use the Vite dev URL when local (e.g. http://localhost:5173).
CLIENT_URL=http://localhost:3000

# Session JWT after GitHub OAuth (required for API Bearer auth). Use a long random string.
JWT_SECRET=
# Optional; default 7
# JWT_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# GitHub deep agents — LangChain ChatOllama → Ollama HTTP API (issue + PR workflows)
# -----------------------------------------------------------------------------
AGENT_LLM_PROVIDER=ollama
MODEL=kimi-k2.5
# Hosted API (default). Set OLLAMA_API_KEY from https://ollama.com (same as ollama.Client).
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
# Self-hosted: OLLAMA_BASE_URL=http://localhost:11434 and leave OLLAMA_API_KEY empty.
# Docker → host Ollama: OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MAX_RETRIES=10
# OLLAMA_TIMEOUT_SEC=120

# -----------------------------------------------------------------------------
# Daytona (optional) — remote sandbox for deep agents
# -----------------------------------------------------------------------------
# If set, agents run in an isolated Daytona sandbox (see LangChain Deep Agents sandboxes).
# If unset, agents use the local virtual filesystem under ./workspace.
# DAYTONA_API_KEY=
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=
# Set to false to force local backend even when DAYTONA_API_KEY is present.
# DAYTONA_AGENT_ENABLED=false

# Linux user for the Daytona sandbox process. Default root (avoids permission friction in ephemeral VMs).
# DAYTONA_SANDBOX_USER=root

# Sandbox HOME (and ~/bin on PATH). Default /root when user is root, else /home/<DAYTONA_SANDBOX_USER>.
# DAYTONA_AGENT_HOME=/root

# Custom snapshot (defaults to greagents-be-custom-snapshot in code). Override with any Daytona snapshot name.
# Use DAYTONA_SNAPSHOT=none (or -) for Daytona's stock language snapshots instead.
# DAYTONA_SNAPSHOT=my-other-snapshot

# Stock Daytona snapshots only: python | typescript | javascript (default typescript if DAYTONA_SNAPSHOT unset).
# DAYTONA_SANDBOX_LANGUAGE=typescript

# Override Daytona CreateSandbox os_user (defaults to DAYTONA_SANDBOX_USER, usually root). Use "none" or "-" to omit.
# DAYTONA_OS_USER=

# Default false (prebuilt sandbox image includes gh). Set true for stock Daytona snapshots without gh.
# DAYTONA_INSTALL_GH_CLI=true
# GITHUB_CLI_VERSION=2.69.0

# -----------------------------------------------------------------------------
# Git author for agent commits (optional; overrides bot identity from GitHub API)
# -----------------------------------------------------------------------------
# GIT_AUTHOR_NAME=my-app[bot]
# GIT_AUTHOR_EMAIL=12345+my-app[bot]@users.noreply.github.com
# GIT_COMMITTER_NAME=
# GIT_COMMITTER_EMAIL=

# -----------------------------------------------------------------------------
# Dodo Payments (required for checkout, portal, and POST /billing/webhook)
# Secrets stay on the server only — never expose in the browser.
# -----------------------------------------------------------------------------
DODO_PAYMENTS_API_KEY=
# Exactly: test_mode  OR  live_mode (invalid values fail billing routes at runtime).
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Standard Webhooks signing secret from the Dodo dashboard.
DODO_PAYMENTS_WEBHOOK_KEY=
# Ship Goblin product id from the Dodo dashboard (e.g. pdt_...).
DODO_PRODUCT_ID_SHIP_GOBLIN=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
SQL_ECHO=false
